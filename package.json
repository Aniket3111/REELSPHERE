{
  "name": "ai-movie-explorer",
  "version": "1.0.0",
  "private": true,
  "description": "AI Movie Explorer with natural language search, recommendations, chat, and taste analysis.",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server.js",
    "dev:client": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@google/generative-ai": "^0.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^5.4.19"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
